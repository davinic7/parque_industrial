APP_ENV=development
APP_DEBUG=1
SITE_URL=http://localhost/parque_industrial
SESSION_COOKIE_SECURE=0
# En producción (Render, etc.): 1 para redirigir HTTP→HTTPS usando X-Forwarded-Proto
FORCE_HTTPS=0

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=parque_industrial
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# MySQL con SSL (Aiven, PlanetScale, etc.): ruta al PEM, p. ej. config/ca.pem
# Dejar vacío para MySQL local sin SSL
DB_SSL_CA=

# Si están definidas, logos, galería, publicaciones y adjuntos PDF (p. ej. mensajes empresa→ministerio) se suben a Cloudinary; en Render sin disco persistente conviene tenerlas para evitar 404 tras redeploy.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cron vía HTTP (Render u otros): misma clave en ?key= de los scripts en public/ministerio/cron/
CRON_SECRET=

# Email transaccional vía Resend (resend.com)
# Crear cuenta → verificar dominio → generar API key → pegar aquí
RESEND_API_KEY=
MAIL_FROM=no-reply@parqueindustrial.gob.ar
